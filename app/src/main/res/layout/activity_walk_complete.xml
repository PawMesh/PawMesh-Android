<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <!-- 상단 파란 배경 -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="#1B3F8B"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 산책을 완료했어요! -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="산책을 완료했어요!"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="@font/mona10x12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- 보리와 1번째 산책을 완료했어요 -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="보리와 1번째 산책을 완료했어요"
        android:textColor="#CCDDFF"
        android:textSize="14sp"
        android:fontFamily="@font/mona10x12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

    <!-- 카드 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="140dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- 두부 & 보리의 산책 기록 -->
            <TextView
                android:id="@+id/tvRecordTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/mona10x12"
                android:text="두부 &amp; 보리의 산책 기록"
                android:textColor="#1B3F8B"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 파란 원 배경 -->
            <ImageView
                android:id="@+id/imageView6"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="16dp"
                app:layout_constraintEnd_toStartOf="@id/imageView7"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvRecordTitle"
                app:srcCompat="@drawable/bluecircle" />

            <!-- 노란 원 배경 -->
            <ImageView
                android:id="@+id/imageView7"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/imageView6"
                app:layout_constraintTop_toBottomOf="@id/tvRecordTitle"
                app:srcCompat="@drawable/yellowcircle" />

            <!-- 강아지 두부 -->
            <ImageView
                android:id="@+id/imageView9"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:layout_constraintBottom_toBottomOf="@id/imageView6"
                app:layout_constraintEnd_toEndOf="@id/imageView6"
                app:layout_constraintStart_toStartOf="@id/imageView6"
                app:layout_constraintTop_toTopOf="@id/imageView6"
                app:srcCompat="@drawable/puppy_dubu" />

            <!-- 강아지 보리 -->
            <ImageView
                android:id="@+id/imageView8"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:layout_constraintBottom_toBottomOf="@id/imageView7"
                app:layout_constraintEnd_toEndOf="@id/imageView7"
                app:layout_constraintStart_toStartOf="@id/imageView7"
                app:layout_constraintTop_toTopOf="@id/imageView7"
                app:srcCompat="@drawable/puppy_bori" />

            <!-- 시간 라벨 -->
            <TextView
                android:id="@+id/tvTimeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="시간"
                android:textColor="#888888"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/tvDistanceLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/imageView6" />

            <!-- 거리 라벨 -->
            <TextView
                android:id="@+id/tvDistanceLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="거리"
                android:textColor="#888888"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/tvCalorieLabel"
                app:layout_constraintStart_toEndOf="@id/tvTimeLabel"
                app:layout_constraintTop_toBottomOf="@id/imageView6" />

            <!-- 소모 칼로리 라벨 -->
            <TextView
                android:id="@+id/tvCalorieLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="소모 칼로리"
                android:textColor="#888888"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvDistanceLabel"
                app:layout_constraintTop_toBottomOf="@id/imageView6" />

            <!-- 45분 -->
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="45분"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tvDistance"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTimeLabel" />

            <!-- 2.3km -->
            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="2.3km"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tvCalorie"
                app:layout_constraintStart_toEndOf="@id/tvTime"
                app:layout_constraintTop_toBottomOf="@id/tvDistanceLabel" />

            <!-- 185kcal -->
            <TextView
                android:id="@+id/tvCalorie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="185kcal"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvDistance"
                app:layout_constraintTop_toBottomOf="@id/tvCalorieLabel" />

            <!-- 경로 배경 -->
            <View
                android:id="@+id/routeMap"
                android:layout_width="318dp"
                android:layout_height="116dp"
                android:layout_marginTop="16dp"
                android:background="#DCFCE7"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTime" />

            <!-- 경로 이미지 -->

            <!-- 날짜 텍스트 -->

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="291dp"
                android:layout_height="42dp"
                android:adjustViewBounds="true"
                app:layout_constraintBottom_toBottomOf="@id/routeMap"
                app:layout_constraintEnd_toEndOf="@id/routeMap"
                app:layout_constraintHorizontal_bias="0.464"
                app:layout_constraintStart_toStartOf="@id/routeMap"
                app:layout_constraintTop_toTopOf="@id/routeMap"
                app:layout_constraintVertical_bias="0.545"
                app:srcCompat="@drawable/bluedotway" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_date_chip"
                android:fontFamily="@font/mona10x12"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="6월 26일 금요일"
                android:textColor="#475569"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/routeMap"
                app:layout_constraintTop_toTopOf="@id/routeMap" />

            <!-- 기록 공유하기 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShare"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/mona10x12"
                android:text="기록 공유하기"
                android:textColor="#1B3F8B"
                app:backgroundTint="#FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/routeMap"
                app:strokeColor="#1B3F8B"
                app:strokeWidth="1dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- 친구 맺기 버튼 -->
    <Button
        android:id="@+id/btnFriend"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#1B3F8B"
        android:text="친구 맺기"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/mona10x12"
        app:layout_constraintTop_toBottomOf="@id/card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 오늘은 여기까지만 할게요 -->
    <TextView
        android:id="@+id/tvSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="오늘은 여기까지만 할게요"
        android:textColor="#888888"
        android:textSize="14sp"
        android:fontFamily="@font/mona10x12"
        app:layout_constraintTop_toBottomOf="@id/btnFriend"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>