<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <!-- 파란 원 (두부) -->
    <ImageView
        android:id="@+id/imgCircleBlue"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="-20dp"
        app:srcCompat="@drawable/bluecircle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/imgCircleYellow"/>

    <!-- 노란 원 (보리) -->
    <ImageView
        android:id="@+id/imgCircleYellow"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="80dp"
        android:layout_marginStart="-20dp"
        app:srcCompat="@drawable/yellowcircle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/imgCircleBlue"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 강아지 두부 -->
    <ImageView
        android:id="@+id/imgDubu"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:srcCompat="@drawable/puppy_dubu"
        app:layout_constraintTop_toTopOf="@id/imgCircleBlue"
        app:layout_constraintBottom_toBottomOf="@id/imgCircleBlue"
        app:layout_constraintStart_toStartOf="@id/imgCircleBlue"
        app:layout_constraintEnd_toEndOf="@id/imgCircleBlue"/>

    <!-- 강아지 보리 -->
    <ImageView
        android:id="@+id/imgBori"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:srcCompat="@drawable/puppy_bori"
        app:layout_constraintTop_toTopOf="@id/imgCircleYellow"
        app:layout_constraintBottom_toBottomOf="@id/imgCircleYellow"
        app:layout_constraintStart_toStartOf="@id/imgCircleYellow"
        app:layout_constraintEnd_toEndOf="@id/imgCircleYellow"/>

    <!-- 하트 배경 원 -->
    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="55dp"
        android:layout_height="55dp"
        app:srcCompat="@drawable/heartcircle"
        app:layout_constraintTop_toTopOf="@id/imgCircleBlue"
        app:layout_constraintBottom_toBottomOf="@id/imgCircleBlue"
        app:layout_constraintEnd_toEndOf="@id/imgCircleBlue"
        app:layout_constraintStart_toStartOf="@id/imgCircleYellow"/>

    <!-- 하트 -->
    <ImageView
        android:id="@+id/imgHeart"
        android:layout_width="32dp"
        android:layout_height="32dp"
        app:srcCompat="@drawable/heart"
        app:layout_constraintTop_toTopOf="@id/imageView2"
        app:layout_constraintBottom_toBottomOf="@id/imageView2"
        app:layout_constraintStart_toStartOf="@id/imageView2"
        app:layout_constraintEnd_toEndOf="@id/imageView2"/>

    <!-- 새로운 친구가 생겼어요! -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="새로운 친구가 생겼어요!"
        android:textColor="#1A1A1A"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/mona10x12"
        app:layout_constraintTop_toBottomOf="@id/imgCircleBlue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 이제 둘은 산책 친구입니다. -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="이제 둘은 산책 친구입니다."
        android:textColor="#888888"
        android:textSize="14sp"
        android:fontFamily="@font/mona10x12"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 카드 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- 첫인사 -->
            <TextView
                android:id="@+id/tvLevelStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/mona10x12"
                android:text="첫인사"
                android:textColor="#888888"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 산책 친구 -->
            <TextView
                android:id="@+id/tvLevelEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/mona10x12"
                android:text="산책 친구"
                android:textColor="#3D6FF0"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 진행 바 -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="14dp"
                android:layout_marginTop="8dp"
                android:progress="30"
                android:progressDrawable="@drawable/progress_rounded"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvLevelStart" />

            <!-- 산책 횟수 -->
            <TextView
                android:id="@+id/tvWalkCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="1"
                android:textColor="#1A1A1A"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tvLevel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progressBar" />

            <!-- 레벨 -->
            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="레벨 2"
                android:textColor="#3D6FF0"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvWalkCount"
                app:layout_constraintTop_toBottomOf="@id/progressBar" />

            <!-- 산책 횟수 라벨 -->
            <TextView
                android:id="@+id/tvWalkCountLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="산책 횟수"
                android:textColor="#888888"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/tvLevelLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvWalkCount" />

            <!-- 친밀도 라벨 -->
            <TextView
                android:id="@+id/tvLevelLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/mona10x12"
                android:gravity="center"
                android:text="친밀도"
                android:textColor="#888888"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvWalkCountLabel"
                app:layout_constraintTop_toBottomOf="@id/tvLevel" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- 친구 목록 보기 버튼 -->
    <Button
        android:id="@+id/btnFriendList"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#3D6FF0"
        android:text="친구 목록 보기"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/mona10x12"
        app:layout_constraintBottom_toTopOf="@id/tvHome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 홈으로 돌아가기 -->
    <TextView
        android:id="@+id/tvHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="홈으로 돌아가기"
        android:textColor="#888888"
        android:textSize="14sp"
        android:fontFamily="@font/mona10x12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>