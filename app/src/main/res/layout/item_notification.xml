<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imgNotifIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:srcCompat="@drawable/noti_heart"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvNotifMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/mona10x12"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="@id/imgNotifIcon"
            app:layout_constraintStart_toEndOf="@id/imgNotifIcon"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvNotifTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:fontFamily="@font/mona10x12"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvNotifMessage"
            app:layout_constraintStart_toEndOf="@id/imgNotifIcon"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
